class Solution {
    public int majorityElement(int[] nums) {
       int candidate = nums[0];
       int count =1;
       int i =1;
       while(i < nums.length){
        if(count == 0){
            candidate = nums[i];
            count++;
        }
        else if(nums[i] == candidate){
            count ++;
        }
        else{
            count--;
        }
        i++;
       }
       return candidate;

    }
}
