class Solution {
    public int cntSubarrays(int[] arr, int k) {
        int count = 0;
        int i = 0;
        while (i < arr.length) {
            int currentSum = 0;
            int j = i;

            while (j < arr.length) {
                currentSum += arr[j];
                if (currentSum == k) {
                    count++;
                }
                j++;
            }
            i++;
        }

        return count;
    }


    
}
